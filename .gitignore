# Python bytecode — created whenever anything runs a module in the repo root
__pycache__/
*.pyc

# Atomic-write scratch files. write_json_atomic() writes <name>.json.tmp and then
# renames it; a run killed mid-write can leave one behind, and it must never be
# committed as if it were published data.
*.tmp

# OS cruft
.DS_Store
Thumbs.db
